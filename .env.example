# SchoolBridge Frontend — API configuration
# Copy to .env.local and adjust when backend is running.

# Live API base URL (leave empty to use demo/mock data only)
VITE_API_URL=

# Force mock data even when API URL is set
# VITE_FORCE_MOCK=true

# Fall back to mock data if API request fails (default: true)
# VITE_API_FALLBACK_MOCK=true

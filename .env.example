# KidsActivites Frontend — API configuration
# Copy to .env or .env.local and adjust when backend is running.

# Live API base URL (required for database-backed data)
# Local machine only:
# VITE_API_URL=http://localhost:8081/api/v1
# VITE_TENANT_SLUG=demo

# LAN / another device on the same network:
# Option A — set your machine's LAN IP explicitly:
VITE_API_URL=http://192.168.1.40:8081/api/v1
# Option B — keep localhost above; if you open the app at http://192.168.x.x:5173
# the frontend auto-rewrites the API host to match (dev only). Restart Vite after .env changes.

# # Live API only — mocks require explicit opt-in
# VITE_FORCE_MOCK=false   
# VITE_API_FALLBACK_MOCK=false

# ── Firebase Cloud Messaging (web push) ─────────────────────────────────────
# Firebase Console → Project settings → General (web app) + Cloud Messaging (VAPID)
# Without these, in-app + STOMP notifications still work; browser push is skipped.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=kidsactivities-25696.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=kidsactivities-25696
# VITE_FIREBASE_STORAGE_BUCKET=kidsactivities-25696.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=

# SchoolBridge Frontend — API configuration
# Copy to .env or .env.local and adjust when backend is running.

# Live API base URL (required for database-backed data)
VITE_API_URL=http://localhost:8080/api/v1

# Tenant slug sent as X-Tenant-Slug header when NOT on a tenant subdomain.
# On {slug}.localhost or {slug}.schoolbridge.app the hostname wins over this value.
VITE_TENANT_SLUG=demo

# Live API only (default). Set to true only for offline UI work without backend.
# VITE_FORCE_MOCK=true

# Fall back to mock data if an API request fails (default: false)
# VITE_API_FALLBACK_MOCK=true

# Force production behaviour locally (derive API URL from subdomain when VITE_API_URL unset)
# VITE_PRODUCTION_MODE=true
